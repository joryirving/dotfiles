// Zed settings — managed by chezmoi.
// Shared settings are below; machine-specific blocks are split by the `personal`
// prompt. Work (non-personal) blocks come from the private `work` submodule.
{
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "autosave": "on_focus_change",
  "session": {
    "trust_all_worktrees": true,
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
  },
{{- if .personal }}
  // ---- personal ----
  // LM Studio runs locally on the Mac (Zed is macOS-only — see .chezmoiignore).
  "edit_predictions": {
    "provider": "open_ai_compatible_api",
    "open_ai_compatible_api": {
      "model": "mellum2-12b-a2.5b-thinking",
      "api_url": "http://localhost:1234/v1",
    },
  },
  "context_servers": {
    "mcp-server-context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {
        "CONTEXT7_API_KEY": "{{ onepasswordRead "op://Kubernetes/context7/ZED_API_KEY" }}",
      },
    },
    // Local server via Homebrew binary (Zed is macOS-only — see .chezmoiignore).
    "github": {
      "command": "/opt/homebrew/lib/node_modules/@modelcontextprotocol/server-github/dist/index.js",
      "args": [],
      "env": {
        "GITHUB_TOKEN": "{{ onepasswordRead "op://Kubernetes/github-miso/GITHUB_TOKEN" }}",
      },
    },
    "memini": {
      "url": "https://memini.jory.dev/mcp",
      "headers": { "X-Memini-Namespace": "zed", "Authorization": "Bearer {{ onepasswordRead "op://Kubernetes/memini/MEMINI_API_KEY" }}" },
    },
    "toolhive": {
      "url": "https://mcp.jory.dev/mcp",
    },
    "konflate": {
      "url": "https://konflate.jory.dev/mcp",
    },
    // Local servers via Homebrew binaries (Zed is macOS-only — see .chezmoiignore).
    "kubectl": {
      "command": "/opt/homebrew/lib/node_modules/@strowk/mcp-k8s-darwin-arm64/bin/mcp-k8s-go",
      "args": [],
    },
    "dispatch": {
      "command": "npx",
      "args": ["tsx", "{{ .chezmoi.homeDir }}/git/dispatch/src/mcp/server.ts"],
      "env": {
        "DISPATCH_URL": "https://dispatch.jory.dev",
        "DISPATCH_AGENT_TOKEN": "{{ onepasswordRead "op://Kubernetes/dispatch/DISPATCH_AGENT_TOKEN" }}",
      },
    },
  },
  "language_models": {
    // Zed auto-discovers whatever models LM Studio currently has loaded.
    "lmstudio": {
      "api_url": "http://localhost:1234/v1",
    },
    "openai_compatible": {
      "LiteLLM": {
        "api_url": "https://litellm.jory.dev/v1",
        "available_models": [
{{ template "shared/litellm-zed-models" . }},
          {
            "name": "chatgpt/gpt-5.5",
            "max_tokens": 400000,
            "max_output_tokens": 128000,
            "capabilities": { "tools": true, "images": true, "parallel_tool_calls": true, "prompt_cache_key": true, "chat_completions": true, "interleaved_reasoning": false }
          },
          {
            "name": "chatgpt/gpt-5.4",
            "max_tokens": 400000,
            "max_output_tokens": 128000,
            "capabilities": { "tools": true, "images": true, "parallel_tool_calls": true, "prompt_cache_key": true, "chat_completions": true, "interleaved_reasoning": false }
          },
          {
            "name": "chatgpt/gpt-5.4-mini",
            "max_tokens": 400000,
            "max_output_tokens": 128000,
            "capabilities": { "tools": true, "images": true, "parallel_tool_calls": true, "prompt_cache_key": true, "chat_completions": true, "interleaved_reasoning": false }
          }
        ]
      }
    },
{{ template "shared/litellm-zed-anthropic" . }},
  },
  "agent": {
    "default_model": {
      "provider": "LiteLLM",
      "model": "auto",
      "enable_thinking": false,
    },
    // Zed has ONE global subagent model (no per-task choice like opencode), so it
    // can't do the "rush → dsv4f" escape — keep subagents local-first on nvidia.
    "subagent_model": {
      "provider": "LiteLLM",
      "model": "nvidia",
      "enable_thinking": false,
    },
    // Commit-message path (Zed routes this around the agent panel; AGENTS.md covers the rest).
    "commit_message_instructions": "Conventional Commits: `type(scope): imperative summary`, lowercase, ~50 char subject. Add a body only if the why isn't obvious from the diff — a few tight lines, no walls, no filler adjectives, don't restate the diff.",
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [
      { "provider": "LiteLLM", "model": "reasoning-pool", "enable_thinking": false },
      { "provider": "LiteLLM", "model": "self-hosted", "enable_thinking": false },
      { "provider": "anthropic", "model": "MiniMax", "enable_thinking": false },
      { "provider": "LiteLLM", "model": "dsv4f", "enable_thinking": false },
      { "provider": "LiteLLM", "model": "dsv4p", "enable_thinking": false },
      { "provider": "LiteLLM", "model": "glm-5.1", "enable_thinking": false },
    ],
    "model_parameters": [],
    // Custom profiles to trim MCP context (built-in write/ask/minimal still apply).
    // tool footprint (defs): kubectl ~23KB, github ~17KB, memory ~10KB, context7 ~5KB,
    // toolhive ~2KB. toolhive is a router (call_tool/find_tool) that reaches every
    // other MCP on demand without injecting their schemas.
    "profiles": {
      "lean": {
        "name": "Lean",
        "enable_all_context_servers": false,
        "tools": {
          "copy_path": true, "create_directory": true, "delete_path": true,
          "diagnostics": true, "edit_file": true, "fetch": true, "find_path": true,
          "grep": true, "list_directory": true, "move_path": true, "read_file": true,
          "terminal": true, "thinking": true
        },
        "context_servers": {
          "toolhive": { "tools": { "call_tool": true, "find_tool": true } }
        }
      },
      "gitops": {
        "name": "GitOps",
        "enable_all_context_servers": false,
        "tools": {
          "copy_path": true, "create_directory": true, "delete_path": true,
          "diagnostics": true, "edit_file": true, "fetch": true, "find_path": true,
          "grep": true, "list_directory": true, "move_path": true, "read_file": true,
          "terminal": true, "thinking": true
        },
        "context_servers": {
          "kubectl": { "tools": {
            "cleanup": true, "kubectl_get": true, "kubectl_describe": true,
            "kubectl_apply": true, "kubectl_delete": true, "kubectl_create": true,
            "kubectl_logs": true, "kubectl_scale": true, "kubectl_patch": true,
            "kubectl_rollout": true, "kubectl_context": true, "kubectl_reconnect": true,
            "explain_resource": true, "install_helm_chart": true, "upgrade_helm_chart": true,
            "uninstall_helm_chart": true, "node_management": true, "port_forward": true,
            "stop_port_forward": true, "exec_in_pod": true, "list_api_resources": true,
            "kubectl_generic": true, "ping": true
          } },
          "konflate": { "tools": {
            "list_pull_requests": true, "get_pr_summary": true, "get_pr_diff": true
          } }
        }
      }
    },
  },
  "file_types": {
    "json5": ["*.json5"],
  },
  "line_ending": "prefer_lf",
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "reasoning_effort": "medium",
        "model": "gpt-5.4",
        "mode": "full-access",
      },
      "type": "registry",
      "env": {
        "CODEX_HOME": "{{ .chezmoi.homeDir }}/.codex",
      },
    },
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
{{- else }}
{{ includeTemplate "work/zed.json" . }}
{{- end }}
}
