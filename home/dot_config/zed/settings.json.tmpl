  "agent": {
    "default_model": {
      "provider": "LiteLLM",
      "model": "nvidia",
      "enable_thinking": false,
    },
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [
      { "provider": "LiteLLM", "model": "self-hosted", "enable_thinking": false },
      { "provider": "anthropic", "model": "MiniMax", "enable_thinking": false },
      { "provider": "LiteLLM", "model": "dsv4f", "enable_thinking": false },
      { "provider": "LiteLLM", "model": "dsv4p", "enable_thinking": false },
      { "provider": "LiteLLM", "model": "glm-5.1", "enable_thinking": false },
    ],
    "model_parameters": [],
    // Custom profiles to trim MCP context (built-in write/ask/minimal still apply).
    // tool footprint (defs): kubectl ~23KB, github ~17KB, memory ~10KB, flux ~8KB,
    // context7 ~5KB, toolhive ~2KB. toolhive is a router (call_tool/find_tool) that
    // reaches every other MCP on demand without injecting their schemas.
    "profiles": {
      "lean": {
        "name": "Lean",
        "enable_all_context_servers": false,
        "tools": {
          "copy_path": true, "create_directory": true, "delete_path": true,
          "diagnostics": true, "edit_file": true, "fetch": true, "find_path": true,
          "grep": true, "list_directory": true, "move_path": true, "read_file": true,
          "terminal": true, "thinking": true
        },
        "context_servers": {
          "toolhive": { "tools": { "call_tool": true, "find_tool": true } }
        }
      },
      "gitops": {
        "name": "GitOps",
        "enable_all_context_servers": false,
        "tools": {
          "copy_path": true, "create_directory": true, "delete_path": true,
          "diagnostics": true, "edit_file": true, "fetch": true, "find_path": true,
          "grep": true, "list_directory": true, "move_path": true, "read_file": true,
          "terminal": true, "thinking": true
        },
        "context_servers": {
          "kubectl": { "tools": {
            "cleanup": true, "kubectl_get": true, "kubectl_describe": true,
            "kubectl_apply": true, "kubectl_delete": true, "kubectl_create": true,
            "kubectl_logs": true, "kubectl_scale": true, "kubectl_patch": true,
            "kubectl_rollout": true, "kubectl_context": true, "kubectl_reconnect": true,
            "explain_resource": true, "install_helm_chart": true, "upgrade_helm_chart": true,
            "uninstall_helm_chart": true, "node_management": true, "port_forward": true,
            "stop_port_forward": true, "exec_in_pod": true, "list_api_resources": true,
            "kubectl_generic": true, "ping": true
          } },
          "flux": { "tools": {
            "apply_kubernetes_manifest": true, "delete_kubernetes_resource": true,
            "get_flux_instance": true, "get_kubeconfig_contexts": true,
            "get_kubernetes_api_versions": true, "get_kubernetes_logs": true,
            "get_kubernetes_metrics": true, "get_kubernetes_resources": true,
            "install_flux_instance": true, "reconcile_flux_helmrelease": true,
            "reconcile_flux_kustomization": true, "reconcile_flux_resourceset": true,
            "reconcile_flux_source": true, "resume_flux_reconciliation": true,
            "search_flux_docs": true, "set_kubeconfig_context": true,
            "suspend_flux_reconciliation": true
          } },
          "konflate": { "tools": {
            "list_pull_requests": true, "get_pr_summary": true, "get_pr_diff": true
          } }
        }
      }
    },
  },
  "file_types": {
    "json5": ["*.json5"],
  },
  "line_ending": "prefer_lf",
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "reasoning_effort": "medium",
        "model": "gpt-5.4",
        "mode": "full-access",
      },
      "type": "registry",
      "env": {
        "CODEX_HOME": "{{ .chezmoi.homeDir }}/.codex",
      },
    },
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
{{- else }}
{{ includeTemplate "work/zed.json" . }}
{{- end }}
}
