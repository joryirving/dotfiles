set -gx KUBE_EDITOR nano
set -gx VISUAL nano
set -gx EDITOR nano
set -gx GOPATH {{ .chezmoi.homeDir }}/.go
set -gx ANSIBLE_FORCE_COLOR true
set -gx ANSIBLE_HOST_KEY_CHECKING False
set -gx PY_COLORS true
set -gx GPG_TTY (tty)
set -gx LANG en_US.utf-8
{{- if .personal }}
# memini bearer token — opencode's memini plugin reads it from env only.
# Scoped named key (defaults to the `opencode` namespace server-side); pass an
# explicit X-Memini-Namespace header to act on other namespaces, or pull the
# admin key from the cluster secret for key-management ops.
set -gx MEMINI_API_KEY "{{ onepasswordRead "op://Kubernetes/memini/OPENCODE_API_KEY" }}"
{{- end }}

fish_add_path --global "{{ .chezmoi.homeDir }}/.local/bin"
fish_add_path --global "{{ .chezmoi.homeDir }}/.cargo/bin"
fish_add_path --global "{{ .chezmoi.homeDir }}/.krew/bin"
fish_add_path --global "{{ .chezmoi.homeDir }}/.go/bin"
fish_add_path --global "{{ .chezmoi.homeDir }}/.opencode/bin"
