{
  "$schema": "https://opencode.ai/config.json"
{{- if .personal }}
  , "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git#f2cbfbe"
    {{/* memini disabled — uncomment the line below to re-enable:
    , ["@eleboucher/opencode-memini@0.4.9", { "base_url": "https://memini.jory.dev", "namespace": "opencode" }]
    */}}
  ]
  , "enabled_providers": [{{ if eq .chezmoi.os "darwin" }}"lmstudio", {{ end }}"litellm-anthropic", "litellm"]
  , "model": "litellm/auto"
  , "provider": {
    {{- if eq .chezmoi.os "darwin" }}
    {{/* LM Studio runs locally on macOS only; absent off-Mac (Rpi5 jumpbox). */}}
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "qwen3.6-35b-a3b": { "name": "Qwen3.6 35B-A3B" },
        "gemma-4-26b-a4b-it-qat": { "name": "Gemma 4 26B" }
      }
    },
    {{- end }}
    "litellm-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "LiteLLM Anthropic",
      "options": {
        "baseURL": "https://litellm.jory.dev/v1",
        "authToken": "{{ onepasswordRead "op://Kubernetes/litellm/LITELLM_MASTER_KEY" }}",
        "timeout": 300000
      },
      "models": {
        "MiniMax-M2.7": { "name": "MiniMax M2.7" },
        "MiniMax": { "name": "MiniMax M3" }
      }
    },
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM OpenAI",
      "options": {
        "baseURL": "https://litellm.jory.dev/v1",
        "apiKey": "{{ onepasswordRead "op://Kubernetes/litellm/LITELLM_MASTER_KEY" }}",
        "timeout": 1800000
      },
      "models": {
        "self-hosted": { "name": "Qwen3.6-35B-A3B", "limit": { "context": 262144, "output": 16384 } },
        "nvidia": { "name": "Qwen3.6-27B", "limit": { "context": 131072, "output": 16384 } },
        "kimi-k2.6": { "name": "Kimi K2.6", "limit": { "context": 262144, "output": 16384 } },
        "glm-5.1": { "name": "GLM 5.1", "limit": { "context": 203000, "output": 16384 } },
        "dsv4f": { "name": "DeepSeek V4 Flash", "limit": { "context": 1000000, "output": 16384 } },
        "dsv4p": { "name": "DeepSeek V4 Pro", "limit": { "context": 1000000, "output": 16384 } },
        "go-kimi-k2.6": { "name": "Go Kimi K2.6", "limit": { "context": 262144, "output": 16384 } },
        "go-minimax-m3": { "name": "Go MiniMax M3", "limit": { "context": 1000000, "output": 32768 } },
        "go-minimax-m2.7": { "name": "Go MiniMax M2.7", "limit": { "context": 204800, "output": 16384 } },
        "mimo-v2.5-pro": { "name": "MiMo V2.5 Pro", "limit": { "context": 262144, "output": 16384 } },
        "mimo-v2.5": { "name": "MiMo V2.5", "limit": { "context": 262144, "output": 16384 } },
        "qwen3.7-plus": { "name": "Qwen3.7 Plus", "limit": { "context": 1000000, "output": 16384 } },
        "chatgpt/gpt-5.5": { "name": "ChatGPT GPT-5.5", "limit": { "context": 400000, "output": 128000 } },
        "chatgpt/gpt-5.4": { "name": "ChatGPT GPT-5.4", "limit": { "context": 400000, "output": 128000 } },
        "chatgpt/gpt-5.4-mini": { "name": "ChatGPT GPT-5.4 Mini", "limit": { "context": 400000, "output": 128000 } },
        "glm-5.2": { "name": "GLM 5.2", "limit": { "context": 1000000, "output": 16384 } },
        "go-glm-5.1": { "name": "Go GLM 5.1", "limit": { "context": 203000, "output": 16384 } },
        {{/* reasoning-pool: load-balanced glm-5.2/dsv4p/kimi (coordinator). auto: complexity router. */}}
        "reasoning-pool": { "name": "Reasoning Pool", "limit": { "context": 262144, "output": 16384 } },
        "auto": { "name": "Auto (router)", "limit": { "context": 131072, "output": 16384 } }
      }
    }
  }
  , "mcp": {
    "mcp-server-context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
      "environment": {
        "CONTEXT7_API_KEY": "{{ onepasswordRead "op://Kubernetes/context7/OPENCODE_API_KEY" }}"
      }
    },
    "toolhive": {
      "type": "remote",
      "url": "https://mcp.jory.dev/mcp"
    },
    "konflate": {
      "type": "remote",
      "url": "https://konflate.jory.dev/mcp"
    },
    "dispatch": {
      "type": "local",
      "command": ["npx", "tsx", "{{ .chezmoi.homeDir }}/git/dispatch/src/mcp/server.ts"],
      "enabled": true,
      "environment": {
        "DISPATCH_URL": "https://dispatch.jory.dev",
        "DISPATCH_AGENT_TOKEN": "{{ onepasswordRead "op://Kubernetes/dispatch/DISPATCH_AGENT_TOKEN" }}"
      }
    }
    {{- if eq .chezmoi.os "darwin" }}
    {{/* macOS-only local servers (Homebrew binaries). Off-Mac (e.g. Rpi5 jumpbox)
         these tools are reached through the toolhive gateway, which aggregates them. */}}
    , "github": {
      "type": "local",
      "command": ["/opt/homebrew/lib/node_modules/@modelcontextprotocol/server-github/dist/index.js"],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{{ onepasswordRead "op://Kubernetes/github-miso/GITHUB_TOKEN" }}"
      }
    }
    , "kubectl": {
      "type": "local",
      "command": ["/opt/homebrew/lib/node_modules/@strowk/mcp-k8s-darwin-arm64/bin/mcp-k8s-go"],
      "enabled": true
    }
    , "flux": {
      "type": "local",
      "command": ["/opt/homebrew/bin/flux-operator-mcp", "serve"],
      "enabled": true,
      "environment": {
        "KUBECONFIG": "{{ .chezmoi.homeDir }}/.kube/config"
      }
    }
    {{- end }}
  }
  , "agent": {
    {{/* Coordinator + role subagents (taxonomy borrowed from oh-my-opencode:
         explorer/fixer/oracle/reviewer, council as a coordinator behavior).
         Strong reasoning coordinator plans and delegates via the task tool;
         everyday default stays `auto`. Tab to coordinator for orchestration. */}}
    "coordinator": {
      "description": "Reasoning coordinator — plans, then delegates to role subagents (explorer/fixer/oracle/reviewer)",
      "mode": "primary",
      "model": "litellm/reasoning-pool",
      "prompt": "You are a coordinator. Do the high-level reasoning and synthesis yourself; delegate the legwork to role subagents via the task tool, local-first.\n\nROLES:\n- `explorer` (cloud dsv4f — cheap, parallel-safe): codebase recon, search, 'where/how is X', read-only. Fan these out freely; it does not consume local slots.\n- `fixer` (nvidia — best/fastest local coder, TWO slots): scoped implementation and edits. Your default code executor.\n- `fixer-bigctx` (self-hosted — TWO slots, vision): implementation needing >131k context or images; also the second local coding lane.\n- `oracle` (reasoning-pool — strongest tier): hard debugging, root-cause, architecture. Read-mostly; return analysis, don't sprawl into edits.\n- `reviewer` (GLM-5.2 — different family from the Qwen coders): independent second opinion and creative/prose.\n\nPARALLEL CODING: keep about four coding tasks in flight locally — up to 2 on `fixer` and 2 on `fixer-bigctx` (two real slots each). Send further parallel coding to `explorer` (its dsv4f backend also codes well) rather than overloading local. A single task goes to `fixer`.\n\nCOUNCIL (high-stakes review): get independent verdicts from two different model families — `reviewer` (GLM) plus `fixer` (Qwen) — then reconcile. Never let one model grade its own work."
    },
    "explorer": {
      "description": "Recon — codebase scouting, search, 'where/how is X', read-only. Cloud (dsv4f): cheap and parallel-safe, fan out freely without touching local slots",
      "mode": "subagent",
      "model": "litellm/dsv4f"
    },
    "fixer": {
      "description": "Scoped implementation — Qwen3.6-27B, best + fastest local coder (131k, no vision). TWO slots: up to two truly concurrent tasks",
      "mode": "subagent",
      "model": "litellm/nvidia"
    },
    "fixer-bigctx": {
      "description": "Big-context / vision implementation — Qwen3.6-35B-A3B (262k, vision), TWO slots. Use when context exceeds 131k or images are involved; also the 2nd local coding lane. Weaker coder than `fixer`",
      "mode": "subagent",
      "model": "litellm/self-hosted"
    },
    "oracle": {
      "description": "Hard debugging / architecture — reasoning-pool (strongest tier). Read-mostly deep analysis; return a recommendation, don't sprawl into edits",
      "mode": "subagent",
      "model": "litellm/reasoning-pool"
    },
    "reviewer": {
      "description": "Independent review / creative — GLM-5.2 (different family from the Qwen coders). Second opinions and prose; GLM-Lite is ~80 prompts/5h, so use sparingly, not high-volume",
      "mode": "subagent",
      "model": "litellm/glm-5.2"
    },
    "lean": {
      "description": "Minimal MCP context — toolhive router only (reaches other MCPs via call_tool)",
      "mode": "primary",
      "tools": {
        "mcp-server-context7*": false,
        "github*": false,
        "kubectl*": false,
        "flux*": false,
        "konflate*": false,
        "dispatch*": false
      }
    },
    "gitops": {
      "description": "Cluster ops — kubectl/flux/konflate direct on macOS; via toolhive router off-Mac",
      "mode": "primary",
      "tools": {
        "mcp-server-context7*": false,
        "github*": false,
        "dispatch*": false
        {{- if eq .chezmoi.os "darwin" }}
        {{/* kubectl/flux run as local binaries here, so reach them directly and
             skip the toolhive router. */}}
        , "toolhive*": false
        {{- end }}
        {{/* Off-Mac the local binaries are absent (see mcp block), so toolhive is
             left enabled — its find_tool/call_tool router reaches kubectl/flux/etc. */}}
      }
    }
  }
{{- else }}
{{ includeTemplate "work/opencode.json" . }}
{{- end }}
}
