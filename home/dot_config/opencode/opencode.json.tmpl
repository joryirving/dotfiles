{
  "$schema": "https://opencode.ai/config.json"
{{- if .personal }}
  , "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git#d884ae04edebef577e82ff7c4e143debd0bbec99"
    {{/* re-enabled: 0.6.9+ fixed the RAG echo that got 0.5.2 disabled — live-session
         captures are excluded from recall and <memory> blocks no longer leak into
         replies (#86). Auth = MEMINI_API_KEY env (scoped opencode key via fish env);
         explicit namespace pinned so per-repo git-basename resolution doesn't
         fragment the existing `opencode` memories. */}}
    , ["@eleboucher/opencode-memini@0.7.5", { "base_url": "https://memini.jory.dev", "namespace": "opencode" }]
  ]
  , "enabled_providers": [{{ if eq .chezmoi.os "darwin" }}"lmstudio", {{ end }}"litellm-anthropic", "litellm"]
  , "model": "litellm/auto"
  , "provider": {
    {{- if eq .chezmoi.os "darwin" }}
    {{/* LM Studio runs locally on macOS only; absent off-Mac (Rpi5 jumpbox). */}}
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "qwen3.6-35b-a3b": { "name": "Qwen3.6 35B-A3B" },
        "gemma-4-26b-a4b-it-qat": { "name": "Gemma 4 26B" }
      }
    },
    {{- end }}
{{ template "shared/litellm-opencode-anthropic" . }},
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM OpenAI",
      "options": {
        "baseURL": "https://litellm.jory.dev/v1",
        "apiKey": "{{ onepasswordRead "op://Kubernetes/litellm/LITELLM_MASTER_KEY" }}",
        "timeout": 1800000
      },
      "models": {
{{ template "shared/litellm-opencode-models" . }},
        "chatgpt/gpt-5.5": { "name": "ChatGPT GPT-5.5", "limit": { "context": 400000, "output": 128000 } },
        "chatgpt/gpt-5.4": { "name": "ChatGPT GPT-5.4", "limit": { "context": 400000, "output": 128000 } },
        "chatgpt/gpt-5.4-mini": { "name": "ChatGPT GPT-5.4 Mini", "limit": { "context": 400000, "output": 128000 } }
      }
    }
  }
  , "mcp": {
    "mcp-server-context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
      "environment": {
        "CONTEXT7_API_KEY": "{{ onepasswordRead "op://Kubernetes/context7/OPENCODE_API_KEY" }}"
      }
    },
    "toolhive": {
      "type": "remote",
      "url": "https://mcp.jory.dev/mcp"
    },
    "konflate": {
      "type": "remote",
      "url": "https://konflate.jory.dev/mcp"
    },
    "dispatch": {
      "type": "local",
      "command": ["npx", "tsx", "{{ .chezmoi.homeDir }}/git/dispatch/src/mcp/server.ts"],
      "enabled": true,
      "environment": {
        "DISPATCH_URL": "https://dispatch.jory.dev",
        "DISPATCH_AGENT_TOKEN": "{{ onepasswordRead "op://Kubernetes/dispatch/DISPATCH_AGENT_TOKEN" }}"
      }
    }
    {{- if eq .chezmoi.os "darwin" }}
    {{/* macOS-only local servers (Homebrew binaries). Off-Mac (e.g. Rpi5 jumpbox)
         these tools are reached through the toolhive gateway, which aggregates them. */}}
    , "github": {
      "type": "local",
      "command": ["/opt/homebrew/lib/node_modules/@modelcontextprotocol/server-github/dist/index.js"],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{{ onepasswordRead "op://Kubernetes/github-miso/GITHUB_TOKEN" }}"
      }
    }
    , "kubectl": {
      "type": "local",
      "command": ["/opt/homebrew/lib/node_modules/@strowk/mcp-k8s-darwin-arm64/bin/mcp-k8s-go"],
      "enabled": true
    }
    {{- end }}
  }
  , "agent": {
    {{/* Coordinator + role subagents (taxonomy borrowed from oh-my-opencode:
         explorer/fixer/fixer-bigctx/oracle/reviewer, council as a coordinator behavior).
         Strong reasoning coordinator plans and delegates via the task tool;
         everyday default stays `auto`. Tab to coordinator for orchestration. */}}
    "coordinator": {
      "description": "Reasoning coordinator — plans, then delegates to role subagents (explorer/fixer/fixer-bigctx/oracle/reviewer)",
      "mode": "primary",
      "model": "litellm/reasoning-pool",
      "prompt": "You are a coordinator. Do the high-level reasoning and synthesis yourself; delegate the legwork to role subagents via the task tool, local-first.\n\nLOCAL-FIRST POLICY: Cloud models are last-resort capacity only. Do not use cloud just for speed, convenience, or because a task is easy to parallelize. Prefer waiting for local lanes or doing the work yourself over spending cloud tokens. Use `explorer` only when all useful local lanes are busy or unsuitable and the task still needs parallel read-only recon.\n\nROLES:\n- `fixer` (nvidia — best/fastest local coder): scoped implementation and edits. Your default code executor; the smaller but highest-quality local lane (131k, no vision).\n- `fixer-bigctx` (self-hosted — Ornith 1.0 35B agentic-coding MoE): big-context coding lane (262k, no vision, 3 slots). Not as smart/fast as `fixer`; use for implementation needing >131k context, independent implementation attempts, alternative fixes, or extra parallel coding capacity.\n- `vision` (standalone vision model): the only image-capable local lane (262k, vision). Use when a task must read images.\n- `explorer` (cloud dsv4f): last-resort read-only recon for codebase search, 'where/how is X', and parallel scouting only after local lanes are unavailable. Never use it as the default overflow just because it is cheap or parallel-safe.\n- `oracle` (reasoning-pool — strongest tier): hard debugging, root-cause, architecture. Read-mostly; return analysis, don't sprawl into edits.\n- `reviewer` (Minimax M3 — different family from the Qwen coders): independent second opinion and creative/prose.\n\nPARALLEL CODING: prefer `fixer` for the most important work, use `fixer-bigctx` as the next local coding lane (and for >131k context), use `vision` when images are involved, and pause or narrow scope before using cloud. Only spill to `explorer` after `fixer` and `fixer-bigctx` are busy or unsuitable. A few tasks goes to `fixer`.\n\nCOUNCIL (high-stakes review): get independent verdicts from two different model families — `reviewer` (Minimax) plus `fixer` (Qwen) — then reconcile. Never let one model grade its own work."
    },
    "explorer": {
      "description": "Last-resort recon — codebase scouting, search, 'where/how is X', read-only. Cloud (dsv4f): use only when local lanes are busy or unsuitable; never fan out just for speed.",
      "mode": "subagent",
      "model": "litellm/dsv4f"
    },
    "fixer": {
      "description": "Scoped implementation — Qwen3.6-27B, best + fastest local coder (131k, no vision). The smaller but highest-quality local lane — prefer it for the most important work",
      "mode": "subagent",
      "model": "litellm/nvidia"
    },
    "fixer-bigctx": {
      "description": "Big-context coding lane — Ornith 1.0 35B agentic-coding MoE (262k, no vision, 3 slots). Not as smart/fast as `fixer`; use for implementation needing >131k context, independent attempts, alternative fixes, or extra parallel coding capacity.",
      "mode": "subagent",
      "model": "litellm/self-hosted"
    },
    "vision": {
      "description": "Vision / image tasks — standalone vision model (262k, vision). The only image-capable local lane; use when a task must read images.",
      "mode": "subagent",
      "model": "litellm/vision"
    },
    "oracle": {
      "description": "Hard debugging / architecture — reasoning-pool (strongest tier). Read-mostly deep analysis; return a recommendation, don't sprawl into edits",
      "mode": "subagent",
      "model": "litellm/reasoning-pool"
    },
    "reviewer": {
      "description": "Independent review / creative — Minimax M3 (different family from the Qwen coders). Second opinions and prose.",
      "mode": "subagent",
      "model": "litellm-anthropic/MiniMax-M3"
    },
    "lean": {
      "description": "Minimal MCP context — toolhive router only (reaches other MCPs via call_tool)",
      "mode": "primary",
      "tools": {
        "mcp-server-context7*": false,
        "github*": false,
        "kubectl*": false,
        "konflate*": false,
        "dispatch*": false
      }
    },
    "gitops": {
      "description": "Cluster ops — kubectl/konflate direct on macOS; via toolhive router off-Mac",
      "mode": "primary",
      "tools": {
        "mcp-server-context7*": false,
        "github*": false,
        "dispatch*": false
        {{- if eq .chezmoi.os "darwin" }}
        {{/* kubectl run as local binary here, so reach them directly and
             skip the toolhive router. */}}
        , "toolhive*": false
        {{- end }}
        {{/* Off-Mac the local binaries are absent (see mcp block), so toolhive is
             left enabled — its find_tool/call_tool router reaches kubectl/etc. */}}
      }
    }
  }
{{- else }}
{{ includeTemplate "work/opencode.json" . }}
{{- end }}
}
